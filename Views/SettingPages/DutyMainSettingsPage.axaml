<ci:SettingsPageBase x:Class="DutyAgent.Views.SettingPages.DutyMainSettingsPage"
                     xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                     xmlns:local="clr-namespace:DutyAgent.Views.SettingPages"
                     x:DataType="local:DutyMainSettingsPage"
                     d:DataContext="{d:DesignInstance local:DutyMainSettingsPage}"
                     mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12,12,18,24">
        <StackPanel Classes="animated-intro" Spacing="0">
            
            <ui:InfoBar x:Name="StatusInfoBar"
                        Margin="0,8,0,16"
                        IsOpen="True"
                        IsClosable="False"
                        Severity="Informational">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,2,0,2">
                        <TextBlock x:Name="StatusText" Text="就绪" FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusMetaText" Text="配置状态：未应用" Opacity="0.78" FontSize="12" />
                        <TextBlock x:Name="RuntimeMetaText" Text="运行状态：待命 | 数据状态：未刷新" Opacity="0.78" FontSize="12" />
                    </StackPanel>
                    <Button x:Name="RefreshDataBtn"
                            Grid.Column="1"
                            Content="刷新数据"
                            Click="OnRefreshDataClick"
                            VerticalAlignment="Center" />
                </Grid>
            </ui:InfoBar>

            <StackPanel Margin="0,4,0,6" Orientation="Horizontal" Spacing="8">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8FD;" FontSize="16" Foreground="#6F6F6F" VerticalAlignment="Center" />
                <TextBlock Text="排班" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <Border Margin="0,0,0,12"
                    Padding="16"
                    Background="#08000000"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="执行排班" FontWeight="SemiBold" />
                            <TextBlock Text="留空时按当前配置执行；填写指令时会覆盖本次排班上下文。"
                                       FontSize="12"
                                       Opacity="0.62"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="RunAgentBtn" Grid.Column="1" Classes="accent" Click="OnRunAgentClick" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" Text="&#xE768;" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="开始排班（覆盖）" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBox x:Name="InstructionBox"
                             Height="76"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="请输入本次排班指令；留空将按当前配置执行默认排班。" />

                    <Border x:Name="ReasoningBoardContainer"
                            IsVisible="False"
                            Background="#08000000"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,2,0,0">
                        <ScrollViewer x:Name="ReasoningBoardScrollViewer" MaxHeight="250" Padding="12">
                            <TextBlock x:Name="ReasoningBoardText"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontSize="13"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,12"
                    Padding="16"
                    Background="#08000000"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="排班与名单" FontWeight="SemiBold" />
                    </StackPanel>
                    <TabControl x:Name="DataViewTabControl">
                        <TabItem Header="排班预览">
                            <StackPanel x:Name="ScheduleViewPanel" Spacing="10" Margin="0,12,0,0">
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="#03000000">
                            <Grid RowDefinitions="Auto,*">
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                    <Grid ColumnDefinitions="120,80,2.4*,1.4*" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="日期" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="星期" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" Text="值日安排" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="3" Text="备注" FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                                <ListBox x:Name="ScheduleListBox"
                                         Grid.Row="1"
                                         MinHeight="220"
                                         MaxHeight="360"
                                         SelectionChanged="OnScheduleSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,12" BorderBrush="#10000000" BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="120,80,2.4*,1.4*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding Date}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Day}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding AssignmentSummary}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Note}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel x:Name="ScheduleEmptyStatePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="False">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" Text="&#xE8A5;" FontSize="48" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock Text="暂无排班预期数据" Opacity="0.6" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="点击顶部【刷新数据】或【开始排班】生成" Opacity="0.5" FontSize="12" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="#04000000" CornerRadius="8" Padding="16,12" Margin="0,4,0,0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="编辑排班详情" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="SelectedScheduleMetaText" Grid.Column="1" Text="请先在上方列表选择记录" Opacity="0.6" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,150,Auto,100" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="日期" VerticalAlignment="Center" Opacity="0.8" />
                                    <TextBox x:Name="ScheduleDateEditorBox" Grid.Column="1" TextChanged="OnScheduleEditorTextChanged" Watermark="yyyy-MM-dd" />
                                    <TextBlock Grid.Column="2" Text="星期" VerticalAlignment="Center" Opacity="0.8" />
                                    <ComboBox x:Name="ScheduleDayEditorComboBox" Grid.Column="3" SelectionChanged="OnScheduleEditorSelectionChanged" HorizontalAlignment="Stretch" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,6,0,0">
                                        <TextBlock Text="安排" Opacity="0.8" />
                                        <TextBlock Text="区域: 姓名" FontSize="12" Opacity="0.5" />
                                    </StackPanel>
                                    <TextBox x:Name="ScheduleAssignmentsEditorBox" Grid.Column="1" TextChanged="OnScheduleEditorTextChanged" Height="64" AcceptsReturn="True" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="备注" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,24,0" />
                                    <TextBox x:Name="ScheduleNoteEditorBox" Grid.Column="1" TextChanged="OnScheduleEditorTextChanged" TextWrapping="Wrap" Watermark="附加说明..." />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
                                    <Button x:Name="CreateScheduleEditBtn" Content="新建记录" Click="OnCreateScheduleEditClick" />
                                    <Button x:Name="ReloadScheduleEditBtn" Content="放弃更改" Click="OnReloadScheduleEditClick" />
                                    <Button x:Name="SaveScheduleEditBtn" Content="保存编辑" Classes="accent" IsEnabled="False" Click="OnSaveScheduleEditClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="ScheduleSummaryText" Text="暂无排班数据。" Opacity="0.75" />
                    </StackPanel>
                        </TabItem>
                        <TabItem Header="花名册管理">
                            <StackPanel x:Name="RosterViewPanel" Spacing="10" Margin="0,12,0,0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="NewStudentNameBox" Width="200" Watermark="输入学生姓名..." />
                                <Button x:Name="AddStudentBtn" Content="添加" Classes="accent" Click="OnAddStudentClick" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ToggleStudentActiveBtn" Content="切换状态" IsEnabled="False" Click="OnToggleStudentActiveClick" />
                                <Button x:Name="DeleteStudentBtn" ToolTip.Tip="删除选中" Click="OnDeleteStudentClick">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" Text="&#xE74D;" Foreground="#E81123" />
                                </Button>
                                <Button x:Name="ImportRosterFromFileBtn" Content="导入..." Click="OnImportRosterFromFileClick" />
                                <Button x:Name="OpenRosterBtn" ToolTip.Tip="打开源文件" Click="OnOpenRosterClick">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" Text="&#xE8E5;" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="#03000000">
                            <Grid RowDefinitions="Auto,*">
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                    <Grid ColumnDefinitions="64,2*,1.8*,84,84" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="姓名" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" Text="下一次值日" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="3" Text="次数" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="4" Text="状态" FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                                <ListBox x:Name="RosterListBox" Grid.Row="1" MinHeight="220" MaxHeight="320" SelectionChanged="OnRosterSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,12" BorderBrush="#10000000" BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="64,2*,1.8*,84,84" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding Id}" VerticalAlignment="Center" Opacity="0.75" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2" Text="{Binding NextDutyDisplay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="3" Text="{Binding DutyCount}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="4" Text="{Binding ActiveDisplay}" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel x:Name="RosterEmptyStatePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="False">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" Text="&#xE716;" FontSize="48" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock Text="当前暂无学生名单数据" Opacity="0.6" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="请在上方添加或导入名单" Opacity="0.5" FontSize="12" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="RosterSummaryText" Text="名单未加载。" Opacity="0.75" />
                    </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>

            <Separator Margin="0,8,0,8" />

            <StackPanel Margin="0,4,0,6" Orientation="Horizontal" Spacing="8">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8B0;" FontSize="16" Foreground="#6F6F6F" VerticalAlignment="Center" />
                <TextBlock Text="规则与自动化" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <ui:SettingsExpander Header="AI 长期规则"
                                 Description="作为固定要求附加到每次排班请求。"
                                 IsExpanded="False">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE945;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="8" Margin="12,0,12,12">
                        <TextBox x:Name="DutyRuleBox"
                                 Height="100"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Watermark="示例：&#10;每天排班2人，跳过周末&#10;区域：教室、清洁区&#10;教室每天2人，清洁区每天3人&#10;排班周期：5天"
                                 LostFocus="OnConfigInputLostFocus"
                                 KeyDown="OnConfigInputKeyDown" />
                    </StackPanel>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="自动排班"
                                 Description="按设定周期自动生成下一轮排班。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE823;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="10" Margin="12,0,12,12">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="触发策略" FontWeight="SemiBold" />
                                <ComboBox x:Name="AutoRunModeComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnConfigSelectionChanged">
                                    <ComboBoxItem Content="关闭" />
                                    <ComboBoxItem Content="每周" />
                                    <ComboBoxItem Content="每月" />
                                    <ComboBoxItem Content="自定义间隔" />
                                </ComboBox>
                                <ComboBox x:Name="AutoRunDayComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnConfigSelectionChanged">
                                    <ComboBoxItem Content="周一" />
                                    <ComboBoxItem Content="周二" />
                                    <ComboBoxItem Content="周三" />
                                    <ComboBoxItem Content="周四" />
                                    <ComboBoxItem Content="周五" />
                                    <ComboBoxItem Content="周六" />
                                    <ComboBoxItem Content="周日" />
                                </ComboBox>
                                <ComboBox x:Name="AutoRunMonthDayComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnConfigSelectionChanged" />
                                <TextBox x:Name="AutoRunIntervalBox"
                                         Watermark="间隔天数（例如 14）"
                                         HorizontalAlignment="Stretch"
                                         LostFocus="OnConfigInputLostFocus"
                                         KeyDown="OnConfigInputKeyDown" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="自动排班时间" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ComboBox x:Name="AutoRunHourComboBox" Width="88" HorizontalAlignment="Left" SelectionChanged="OnConfigSelectionChanged" />
                                        <TextBlock VerticalAlignment="Center" Text="时" />
                                        <ComboBox x:Name="AutoRunMinuteComboBox" Width="88" HorizontalAlignment="Left" SelectionChanged="OnConfigSelectionChanged" />
                                        <TextBlock VerticalAlignment="Center" Text="分" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="组件刷新时间" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ComboBox x:Name="ComponentRefreshHourComboBox" Width="88" HorizontalAlignment="Left" SelectionChanged="OnConfigSelectionChanged" />
                                        <TextBlock VerticalAlignment="Center" Text="时" />
                                        <ComboBox x:Name="ComponentRefreshMinuteComboBox" Width="88" HorizontalAlignment="Left" SelectionChanged="OnConfigSelectionChanged" />
                                        <TextBlock VerticalAlignment="Center" Text="分" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <ToggleSwitch x:Name="AutoRunTriggerNotificationSwitch" Content="自动排班触发通知" Checked="OnConfigToggleChanged" Unchecked="OnConfigToggleChanged" />
                    </StackPanel>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="值日提醒"
                                 Description="在设定时间提醒当天值日安排。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpander.Footer>
                    <ToggleSwitch x:Name="DutyReminderEnabledSwitch" Content="启用值日定时通知" Checked="OnConfigToggleChanged" Unchecked="OnConfigToggleChanged" />
                </ui:SettingsExpander.Footer>
                <StackPanel Spacing="10" Margin="12,0,12,12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="提醒时间" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ComboBox x:Name="DutyReminderHourComboBox" Width="88" HorizontalAlignment="Left" SelectionChanged="OnConfigSelectionChanged" />
                            <TextBlock VerticalAlignment="Center" Text="时" />
                            <ComboBox x:Name="DutyReminderMinuteComboBox" Width="88" HorizontalAlignment="Left" SelectionChanged="OnConfigSelectionChanged" />
                            <TextBlock VerticalAlignment="Center" Text="分" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="通知显示时长" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Slider x:Name="NotificationDurationSlider" Minimum="3" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True" Width="240" ValueChanged="OnNotificationDurationChanged" />
                            <TextBlock x:Name="NotificationDurationLabel" VerticalAlignment="Center" Text="8 秒" />
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="TestNotificationButton" Content="&#xE7F4;  测试通知" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" Click="OnTestNotificationClicked" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:SettingsExpander>

            <Separator Margin="0,8,0,8" />

            <StackPanel Margin="0,4,0,6" Orientation="Horizontal" Spacing="8">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE774;" FontSize="16" Foreground="#6F6F6F" VerticalAlignment="Center" />
                <TextBlock Text="连接与高级" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <ui:SettingsExpander Header="模型服务"
                                 Description="配置调用 AI 排班所需的模型接口。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE8D2;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="10" Margin="12,0,12,12">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Spacing="2" Margin="0,0,32,0">
                                <TextBlock Text="API Key" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="用于访问模型接口；留空时无法执行 AI 排班。" FontSize="12" Opacity="0.55" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="ApiKeyBox" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" PasswordChar="*" LostFocus="OnConfigInputLostFocus" KeyDown="OnConfigInputKeyDown" />

                            <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Spacing="2" Margin="0,0,32,0">
                                <TextBlock Text="模型名称" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="例如：moonshotai/kimi-k2-thinking。" FontSize="12" Opacity="0.55" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="ModelBox" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Watermark="moonshotai/kimi-k2-thinking" LostFocus="OnConfigInputLostFocus" KeyDown="OnConfigInputKeyDown" />

                            <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Spacing="2" Margin="0,0,32,0">
                                <TextBlock Text="提示词模式" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="高性能模型通常选常规，本地小模型更适合增量。" FontSize="12" Opacity="0.55" VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="PromptModeComboBox" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" SelectionChanged="OnConfigSelectionChanged">
                                <ComboBoxItem Content="常规 (高智商大模型)" Tag="Regular" />
                                <ComboBoxItem Content="增量 (本地小尺寸模型)" Tag="Incremental" />
                            </ComboBox>

                            <StackPanel Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Spacing="2" Margin="0,0,32,0">
                                <TextBlock Text="Base URL" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="提供 OpenAI 兼容接口时再填写；官方直连可保持默认。" FontSize="12" Opacity="0.55" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="BaseUrlBox" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Watermark="https://integrate.api.nvidia.com/v1" LostFocus="OnConfigInputLostFocus" KeyDown="OnConfigInputKeyDown" />
                        </Grid>
                    </StackPanel>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="MCP 导入接口"
                                 Description="允许外部通过 MCP 导入值日相关数据。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE943;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpander.Footer>
                    <ToggleSwitch x:Name="EnableMcpSwitch" Content="启用" Checked="OnConfigToggleChanged" Unchecked="OnConfigToggleChanged" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="WebView2 调试层"
                                 Description="为内嵌 WebView2 启用本地调试支持。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE943;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpander.Footer>
                    <ToggleSwitch x:Name="EnableWebDebugLayerSwitch" Content="启用" Checked="OnConfigToggleChanged" Unchecked="OnConfigToggleChanged" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

        </StackPanel>
        </Grid>
    </ScrollViewer>
</ci:SettingsPageBase>
