<ci:SettingsPageBase x:Class="DutyAgent.Views.SettingPages.DutyMainSettingsPage"
                     xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                     xmlns:local="clr-namespace:DutyAgent.Views.SettingPages"
                     x:DataType="local:DutyMainSettingsPage"
                     d:DataContext="{d:DesignInstance local:DutyMainSettingsPage}"
                     mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Classes="settings-container animated-intro">

            <ui:InfoBar x:Name="StatusInfoBar"
                        Margin="0,0,0,12"
                        IsOpen="True"
                        IsClosable="False"
                        Severity="Informational"
                        Title="就绪"
                        Message="配置状态：未应用（--:--:--）&#10;运行状态：待命（--:--:--）｜数据状态：未刷新（--:--:--）">
                <ui:InfoBar.ActionButton>
                    <Button x:Name="RefreshDataBtn"
                            Click="OnRefreshDataClick"
                            VerticalAlignment="Center">
                        <ci:IconText Glyph="&#xE0B5;" Text="刷新数据" />
                    </Button>
                </ui:InfoBar.ActionButton>
            </ui:InfoBar>

            <ci:IconText Glyph="&#xE8FD;" Text="排班" Margin="0,0,0,4" />

            <ui:SettingsExpander Header="执行排班"
                                 Description="留空时按当前方案执行；填写指令会覆盖本次排班上下文。"
                                 IsExpanded="True">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE768;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpander.Footer>
                    <Button x:Name="RunAgentBtn"
                            Classes="accent"
                            Click="OnRunAgentClick">
                        <ci:IconText Glyph="&#xE768;" Text="开始排班（覆盖）" />
                    </Button>
                </ui:SettingsExpander.Footer>
                <StackPanel Spacing="12" Margin="12,0,12,12">
                    <TextBox x:Name="InstructionBox"
                             Height="76"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="请输入本次排班指令；留空将按当前配置执行默认排班。" />

                    <Border x:Name="ReasoningBoardContainer"
                            IsVisible="False"
                            Margin="0,2,0,0"
                            Background="#08000000"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ScrollViewer x:Name="ReasoningBoardScrollViewer"
                                      MaxHeight="250"
                                      Padding="12">
                            <TextBlock x:Name="ReasoningBoardText"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontSize="13"
                                       Opacity="0.85"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="排班方案"
                                 Description="直接维护可运行的方案预设；开始排班时使用当前选中的方案。"
                                 IsExpanded="True"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE7C1;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpanderItem Content="当前方案"
                                         Description="选择本次排班使用的方案，也可以在这里新建、复制和删除方案。">
                    <ui:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox x:Name="CurrentPlanComboBox"
                                      Width="176"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnCurrentPlanSelectionChanged" />
                            <Button x:Name="CreatePlanBtn"
                                    Click="OnCreatePlanClick"
                                    MinWidth="68"
                                    Content="新建" />
                            <Button x:Name="DuplicatePlanBtn"
                                    Click="OnDuplicatePlanClick"
                                    MinWidth="68"
                                    Content="复制当前" />
                            <Button x:Name="DeletePlanBtn"
                                    Click="OnDeletePlanClick"
                                    MinWidth="68"
                                    Content="删除" />
                        </StackPanel>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="方案名称"
                                         Description="名称只用于识别当前方案，不影响实际调用。">
                    <ui:SettingsExpanderItem.Footer>
                        <TextBox x:Name="PlanNameBox"
                                 Width="320"
                                 TextChanged="OnConfigInputTextChanged"
                                 LostFocus="OnConfigInputLostFocus"
                                 KeyDown="OnConfigInputKeyDown" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="执行模式"
                                         Description="决定当前方案采用哪种排班执行方式。">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="PlanModeComboBox"
                                  Width="220"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnConfigSelectionChanged">
                            <ComboBoxItem Content="标准" Tag="standard" />
                            <ComboBoxItem Content="6Agent" Tag="campus_6agent" />
                            <ComboBoxItem Content="增量小模型" Tag="incremental_small" />
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem x:Name="PlanModeHintItem"
                                         Content="模式说明"
                                         Description="帮助快速判断当前方案的执行特点。">
                    <ui:SettingsExpanderItem.Footer>
                        <TextBlock x:Name="PlanModeHintText"
                                   Width="320"
                                   Opacity="0.82"
                                   TextWrapping="Wrap" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem x:Name="MultiAgentExecutionModeItem"
                                         Content="6Agent 执行顺序"
                                         Description="仅对 6Agent 方案生效。">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="MultiAgentExecutionModeComboBox"
                                  Width="220"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnConfigSelectionChanged">
                            <ComboBoxItem Content="自动" Tag="auto" />
                            <ComboBoxItem Content="并发执行" Tag="parallel" />
                            <ComboBoxItem Content="串行执行" Tag="serial" />
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="API Key"
                                         Description="用于访问模型接口；留空时无法执行 AI 排班。">
                    <ui:SettingsExpanderItem.Footer>
                        <TextBox x:Name="ApiKeyBox"
                                 Width="320"
                                 PasswordChar="*"
                                 TextChanged="OnConfigInputTextChanged"
                                 LostFocus="OnConfigInputLostFocus"
                                 KeyDown="OnConfigInputKeyDown" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="模型名称"
                                         Description="例如：moonshotai/kimi-k2-thinking。">
                    <ui:SettingsExpanderItem.Footer>
                        <TextBox x:Name="ModelBox"
                                 Width="320"
                                 Watermark="moonshotai/kimi-k2-thinking"
                                 TextChanged="OnConfigInputTextChanged"
                                 LostFocus="OnConfigInputLostFocus"
                                 KeyDown="OnConfigInputKeyDown" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="Base URL"
                                         Description="提供 OpenAI 兼容接口时再填写；官方直连可保持默认。">
                    <ui:SettingsExpanderItem.Footer>
                        <TextBox x:Name="BaseUrlBox"
                                 Width="320"
                                 Watermark="https://integrate.api.nvidia.com/v1"
                                 TextChanged="OnConfigInputTextChanged"
                                 LostFocus="OnConfigInputLostFocus"
                                 KeyDown="OnConfigInputKeyDown" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="模型画像"
                                         Description="帮助后端选择更合适的提示词组织方式。">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="ModelProfileComboBox"
                                  Width="220"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnConfigSelectionChanged">
                            <ComboBoxItem Content="自动" Tag="auto" />
                            <ComboBoxItem Content="云模型" Tag="cloud" />
                            <ComboBoxItem Content="校内小模型" Tag="campus_small" />
                            <ComboBoxItem Content="边缘模型" Tag="edge" />
                            <ComboBoxItem Content="自定义" Tag="custom" />
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="AI 长期规则"
                                 Description="作为固定要求附加到每次排班请求。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE945;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="8" Margin="12,0,12,12">
                    <TextBox x:Name="DutyRuleBox"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="示例：&#10;每天排班 2 人，跳过周末&#10;区域：教室、清洁区&#10;教室每天 2 人，清洁区每天 2 人&#10;排班周期：7 天"
                             TextChanged="OnConfigInputTextChanged"
                             LostFocus="OnConfigInputLostFocus"
                             KeyDown="OnConfigInputKeyDown" />
                </StackPanel>
            </ui:SettingsExpander>

            <Separator Margin="0,12,0,4" />

            <ci:IconText Glyph="&#xE9D2;" Text="结果与数据" Margin="0,0,0,4" />

            <TabControl x:Name="DataViewTabControl" Margin="0,4,0,0">
                <TabItem Header="排班预览">
                    <StackPanel x:Name="ScheduleViewPanel" Spacing="10" Margin="0,12,0,0">
                        <Border Background="#03000000"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid RowDefinitions="Auto,*">
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="10,8">
                                    <Grid ColumnDefinitions="120,80,2.4*,1.4*" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="日期" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="星期" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" Text="值日安排" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="3" Text="备注" FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                                <ListBox x:Name="ScheduleListBox"
                                         Grid.Row="1"
                                         MinHeight="220"
                                         MaxHeight="360"
                                         SelectionChanged="OnScheduleSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,12" BorderBrush="#10000000" BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="120,80,2.4*,1.4*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Text="{Binding Date}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Day}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding AssignmentSummary}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Note}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel x:Name="ScheduleEmptyStatePanel"
                                            Grid.Row="1"
                                            HorizontalAlignment="Center"
                                            IsVisible="False"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol"
                                               Text="&#xE8A5;"
                                               FontSize="48"
                                               Opacity="0.4"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="暂无排班预览数据"
                                               Opacity="0.6"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="点击顶部【刷新数据】或【开始排班】生成。"
                                               Opacity="0.5"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="#04000000"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,4,0,0"
                                Padding="16,12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="编辑排班详情"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SelectedScheduleMetaText"
                                               Grid.Column="1"
                                               Margin="12,0,0,0"
                                               FontSize="12"
                                               Opacity="0.6"
                                               Text="请先在上方列表选择记录"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,150,Auto,100" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="日期" VerticalAlignment="Center" Opacity="0.8" />
                                    <TextBox x:Name="ScheduleDateEditorBox"
                                             Grid.Column="1"
                                             TextChanged="OnScheduleEditorTextChanged"
                                             Watermark="yyyy-MM-dd" />
                                    <TextBlock Grid.Column="2" Text="星期" VerticalAlignment="Center" Opacity="0.8" />
                                    <ComboBox x:Name="ScheduleDayEditorComboBox"
                                              Grid.Column="3"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnScheduleEditorSelectionChanged" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,6,0,0">
                                        <TextBlock Text="安排" Opacity="0.8" />
                                        <TextBlock Text="区域: 姓名" FontSize="12" Opacity="0.5" />
                                    </StackPanel>
                                    <TextBox x:Name="ScheduleAssignmentsEditorBox"
                                             Grid.Column="1"
                                             Height="64"
                                             AcceptsReturn="True"
                                             TextChanged="OnScheduleEditorTextChanged"
                                             TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               Text="备注"
                                               Margin="0,0,24,0"
                                               Opacity="0.8"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="ScheduleNoteEditorBox"
                                             Grid.Column="1"
                                             TextChanged="OnScheduleEditorTextChanged"
                                             TextWrapping="Wrap"
                                             Watermark="附加说明..." />
                                </Grid>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right"
                                            Margin="0,4,0,0">
                                    <Button x:Name="CreateScheduleEditBtn"
                                            Content="新建记录"
                                            Click="OnCreateScheduleEditClick" />
                                    <Button x:Name="ReloadScheduleEditBtn"
                                            Content="放弃更改"
                                            Click="OnReloadScheduleEditClick" />
                                    <Button x:Name="SaveScheduleEditBtn"
                                            Classes="accent"
                                            Content="保存编辑"
                                            IsEnabled="False"
                                            Click="OnSaveScheduleEditClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="ScheduleSummaryText" Text="暂无排班数据。" Opacity="0.75" />
                    </StackPanel>
                </TabItem>

                <TabItem Header="花名册管理">
                    <StackPanel x:Name="RosterViewPanel" Spacing="10" Margin="0,12,0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="NewStudentNameBox"
                                         Width="220"
                                         Watermark="输入学生姓名..." />
                                <Button x:Name="AddStudentBtn"
                                        Classes="accent"
                                        Content="添加"
                                        Click="OnAddStudentClick" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ToggleStudentActiveBtn"
                                        Content="启用/停用选中"
                                        IsEnabled="False"
                                        Click="OnToggleStudentActiveClick" />
                                <Button x:Name="DeleteStudentBtn"
                                        ToolTip.Tip="删除选中"
                                        Click="OnDeleteStudentClick">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol"
                                               Foreground="#E81123"
                                               Text="&#xE74D;" />
                                </Button>
                                <Button x:Name="ImportRosterFromFileBtn"
                                        Content="导入..."
                                        Click="OnImportRosterFromFileClick" />
                                <Button x:Name="OpenRosterBtn"
                                        ToolTip.Tip="打开源文件"
                                        Click="OnOpenRosterClick">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol"
                                               Text="&#xE8E5;" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="RosterDropZone"
                              DragDrop.AllowDrop="True"
                              DragDrop.DragOver="OnRosterDropZoneDragOver"
                              DragDrop.DragLeave="OnRosterDropZoneDragLeave"
                              DragDrop.Drop="OnRosterDropZoneDrop">
                            <Border Background="#03000000"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid RowDefinitions="Auto,*">
                                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="10,8">
                                        <Grid ColumnDefinitions="64,2*,1.8*,84,84" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="姓名" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="下一次值日" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="3" Text="次数" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="4" Text="状态" FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>
                                    <ListBox x:Name="RosterListBox"
                                             Grid.Row="1"
                                             MinHeight="220"
                                             MaxHeight="320"
                                             SelectionChanged="OnRosterSelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,12" BorderBrush="#10000000" BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="64,2*,1.8*,84,84" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Text="{Binding Id}" VerticalAlignment="Center" Opacity="0.75" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" Text="{Binding NextDutyDisplay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="3" Text="{Binding DutyCount}" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="4" Text="{Binding ActiveDisplay}" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel x:Name="RosterEmptyStatePanel"
                                                Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                IsVisible="False"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol"
                                                   Text="&#xE716;"
                                                   FontSize="48"
                                                   Opacity="0.4"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="当前暂无学生名单数据"
                                                   Opacity="0.6"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="请在上方添加、导入或直接拖入名单文件。"
                                                   Opacity="0.5"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border x:Name="RosterDropOverlay"
                                    IsVisible="False"
                                    IsHitTestVisible="False"
                                    Background="#15007ACC"
                                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol"
                                               Text="&#xE898;"
                                               FontSize="40"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="松手导入名单文件"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="支持 .txt 和 .xlsx"
                                               Opacity="0.72"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="RosterSummaryText" Text="名单未加载。" Opacity="0.75" />
                    </StackPanel>
                </TabItem>
            </TabControl>

            <Separator Margin="0,12,0,4" />

            <ci:IconText Glyph="&#xE823;" Text="自动运行" Margin="0,0,0,4" />

            <ui:SettingsExpander Header="自动排班"
                                 Description="按设定周期自动生成下一轮排班。"
                                 IsExpanded="False">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE823;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpanderItem Content="触发策略"
                                         Description="选择自动排班的执行频率。">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="AutoRunModeComboBox"
                                  Width="220"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnConfigSelectionChanged">
                            <ComboBoxItem Content="关闭" />
                            <ComboBoxItem Content="每周" />
                            <ComboBoxItem Content="每月" />
                            <ComboBoxItem Content="自定义间隔" />
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem x:Name="AutoRunWeeklyItem"
                                         Content="每周日期"
                                         Description="仅在每周模式下使用。">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="AutoRunDayComboBox"
                                  Width="220"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnConfigSelectionChanged">
                            <ComboBoxItem Content="周一" />
                            <ComboBoxItem Content="周二" />
                            <ComboBoxItem Content="周三" />
                            <ComboBoxItem Content="周四" />
                            <ComboBoxItem Content="周五" />
                            <ComboBoxItem Content="周六" />
                            <ComboBoxItem Content="周日" />
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem x:Name="AutoRunMonthlyItem"
                                         Content="每月日期"
                                         Description="仅在每月模式下使用。">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="AutoRunMonthDayComboBox"
                                  Width="220"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnConfigSelectionChanged" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem x:Name="AutoRunIntervalItem"
                                         Content="间隔天数"
                                         Description="仅在自定义间隔模式下使用。">
                    <ui:SettingsExpanderItem.Footer>
                        <TextBox x:Name="AutoRunIntervalBox"
                                 Width="220"
                                 HorizontalAlignment="Stretch"
                                 Watermark="间隔天数，例如 14"
                                 TextChanged="OnConfigInputTextChanged"
                                 LostFocus="OnConfigInputLostFocus"
                                 KeyDown="OnConfigInputKeyDown" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="自动排班时间"
                                         Description="控制自动排班在一天中的执行时间。">
                    <ui:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ci:Field Suffix="时">
                                <ComboBox x:Name="AutoRunHourComboBox"
                                          Width="88"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnConfigSelectionChanged" />
                            </ci:Field>
                            <ci:Field Suffix="分">
                                <ComboBox x:Name="AutoRunMinuteComboBox"
                                          Width="88"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnConfigSelectionChanged" />
                            </ci:Field>
                        </StackPanel>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="组件刷新时间"
                                         Description="控制首页组件刷新值日数据的时间。">
                    <ui:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ci:Field Suffix="时">
                                <ComboBox x:Name="ComponentRefreshHourComboBox"
                                          Width="88"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnConfigSelectionChanged" />
                            </ci:Field>
                            <ci:Field Suffix="分">
                                <ComboBox x:Name="ComponentRefreshMinuteComboBox"
                                          Width="88"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnConfigSelectionChanged" />
                            </ci:Field>
                        </StackPanel>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="触发时通知"
                                         Description="自动排班启动时发送一条通知。">
                    <ui:SettingsExpanderItem.Footer>
                        <ToggleSwitch x:Name="AutoRunTriggerNotificationSwitch"
                                      VerticalAlignment="Center"
                                      Checked="OnConfigToggleChanged"
                                      Unchecked="OnConfigToggleChanged" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="值日提醒"
                                 Description="在设定时间提醒当天值日安排。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpander.Footer>
                    <ToggleSwitch x:Name="DutyReminderEnabledSwitch"
                                  VerticalAlignment="Center"
                                  Checked="OnConfigToggleChanged"
                                  Unchecked="OnConfigToggleChanged" />
                </ui:SettingsExpander.Footer>
                <ui:SettingsExpanderItem Content="提醒时间"
                                         Description="控制当天值日通知的提醒时刻。">
                    <ui:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ci:Field Suffix="时">
                                <ComboBox x:Name="DutyReminderHourComboBox"
                                          Width="88"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnConfigSelectionChanged" />
                            </ci:Field>
                            <ci:Field Suffix="分">
                                <ComboBox x:Name="DutyReminderMinuteComboBox"
                                          Width="88"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnConfigSelectionChanged" />
                            </ci:Field>
                        </StackPanel>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="通知显示时长"
                                         Description="控制提醒在屏幕上的停留时间。">
                    <ui:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Slider x:Name="NotificationDurationSlider"
                                    Minimum="3"
                                    Maximum="15"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Width="240"
                                    ValueChanged="OnNotificationDurationChanged" />
                            <TextBlock x:Name="NotificationDurationLabel"
                                       VerticalAlignment="Center"
                                       Text="8 秒" />
                        </StackPanel>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
                <ui:SettingsExpanderItem Content="测试通知"
                                         Description="立刻预览当前提醒样式。">
                    <ui:SettingsExpanderItem.Footer>
                        <Button x:Name="TestNotificationButton" Click="OnTestNotificationClicked">
                            <ci:IconText Glyph="&#xE7F4;" Text="测试通知" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>
            </ui:SettingsExpander>

            <Separator Margin="0,12,0,4" />

            <ci:IconText Glyph="&#xE7BA;" Text="高级设置" Margin="0,0,0,4" />

            <ui:SettingsExpander Header="访问鉴权"
                                 Description="统一控制 REST、WebSocket、MCP 与页面访问令牌。访问鉴权更改在重启应用后生效。"
                                 IsExpanded="False"
                                 Margin="0,0,0,12">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="8" Margin="12,0,12,12">
                    <ui:SettingsExpanderItem Content="Token 模式"
                                             Description="动态模式随 Python 后端启动重新生成；静态模式使用本地保存的固定 token。">
                        <ui:SettingsExpanderItem.Footer>
                            <ComboBox x:Name="AccessTokenModeComboBox"
                                      Width="220"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnAccessTokenModeSelectionChanged">
                                <ComboBoxItem Content="动态 token" Tag="dynamic" />
                                <ComboBoxItem Content="静态 token" Tag="static" />
                            </ComboBox>
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                    <ui:SettingsExpanderItem Content="当前状态"
                                             Description="显示当前已保存的鉴权模式、静态 token 配置状态，以及当前 token 是否可复制。">
                        <ui:SettingsExpanderItem.Footer>
                            <TextBlock x:Name="AccessTokenStatusText"
                                       Width="360"
                                       Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="访问鉴权尚未加载。" />
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                    <ui:SettingsExpanderItem Content="静态 Token"
                                             Description="仅在切换到静态模式时提交；已保存的静态 token 不会回填显示。">
                        <ui:SettingsExpanderItem.Footer>
                            <TextBox x:Name="StaticAccessTokenBox"
                                     Width="320"
                                     PasswordChar="*"
                                     Watermark="输入新的静态 token" />
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                </StackPanel>
                <ui:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ApplyAccessSecurityBtn"
                                Click="OnApplyAccessSecurityClick"
                                MinWidth="110"
                                Content="应用鉴权设置" />
                        <Button x:Name="CopyAccessTokenBtn"
                                Click="OnCopyAccessTokenClick"
                                MinWidth="110"
                                Content="复制当前 token" />
                        <Button x:Name="ClearStaticAccessTokenBtn"
                                Click="OnClearStaticAccessTokenClick"
                                MinWidth="110"
                                Content="清除静态 token" />
                    </StackPanel>
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:InfoBar Margin="0,0,0,12"
                        IsOpen="True"
                        IsClosable="False"
                        Severity="Warning"
                        Title="谨慎修改"
                        Message="以下选项主要用于扩展接入和问题排查，除非您明确知道用途，否则建议保持默认。" />

            <ui:SettingsExpander Header="MCP 导入接口"
                                 Description="允许外部通过 MCP 导入值日相关数据。服务端口会同时影响 MCP、REST API 与页面访问。修改后建议重启应用。"
                                 IsExpanded="False">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE943;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="8" Margin="12,0,12,12">
                    <ui:SettingsExpanderItem Content="启用 MCP"
                                             Description="关闭后将不再暴露 /mcp 接口，但服务端口仍会继续用于 API 与页面。">
                        <ui:SettingsExpanderItem.Footer>
                            <ToggleSwitch x:Name="EnableMcpSwitch"
                                          VerticalAlignment="Center"
                                          Checked="OnConfigToggleChanged"
                                          Unchecked="OnConfigToggleChanged" />
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                    <ui:SettingsExpanderItem Content="服务端口模式"
                                             Description="随机端口适合宿主内部链路；固定端口适合外部 MCP 客户端长期接入。">
                        <ui:SettingsExpanderItem.Footer>
                            <ComboBox x:Name="ServerPortModeComboBox"
                                      Width="220"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnConfigSelectionChanged">
                                <ComboBoxItem Content="随机端口" Tag="random" />
                                <ComboBoxItem Content="固定端口" Tag="fixed" />
                            </ComboBox>
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                    <ui:SettingsExpanderItem x:Name="FixedServerPortItem"
                                             Content="固定服务端口"
                                             Description="仅在固定端口模式下生效。若端口冲突，后端会回退到随机端口并在本次运行禁用 MCP。">
                        <ui:SettingsExpanderItem.Footer>
                            <TextBox x:Name="FixedServerPortBox"
                                     Width="220"
                                     HorizontalAlignment="Stretch"
                                     Watermark="输入 1024-65535"
                                     TextChanged="OnConfigInputTextChanged" />
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                    <ui:SettingsExpanderItem Content="当前状态"
                                             Description="显示当前实际端口、MCP 地址以及当前运行是否可复制客户端配置。">
                        <ui:SettingsExpanderItem.Footer>
                            <TextBlock x:Name="McpEndpointStatusText"
                                       Width="420"
                                       Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="MCP 状态尚未加载。" />
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                </StackPanel>
                <ui:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CopyMcpUrlBtn"
                                Click="OnCopyMcpUrlClick"
                                MinWidth="110"
                                Content="复制 MCP URL" />
                        <Button x:Name="CopyMcpClientConfigBtn"
                                Click="OnCopyMcpClientConfigClick"
                                MinWidth="140"
                                Content="复制 MCP 客户端配置" />
                    </StackPanel>
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="WebView2 调试层"
                                 Description="启用本地调试支持与调试页，用于排查 WebView2 相关问题。修改后建议重启应用。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE7BA;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <ui:SettingsExpander.Footer>
                    <ToggleSwitch x:Name="EnableWebDebugLayerSwitch"
                                  VerticalAlignment="Center"
                                  Checked="OnConfigToggleChanged"
                                  Unchecked="OnConfigToggleChanged" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="插件数据"
                                 Description="ClassIsland 卸载插件时不会自动删除该插件的配置目录；如果需要真正清空 Duty-Agent 的配置、名单和排班状态，请使用这里的重置操作。"
                                 IsExpanded="False"
                                 Margin="0,4,0,0">
                <ui:SettingsExpander.IconSource>
                    <ui:FontIconSource Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                </ui:SettingsExpander.IconSource>
                <StackPanel Spacing="8" Margin="12,0,12,12">
                    <ui:SettingsExpanderItem Content="当前数据目录"
                                             Description="这里保存插件设置、后端配置、名单和排班状态；重装插件不会自动清空它。">
                        <ui:SettingsExpanderItem.Footer>
                            <TextBlock x:Name="PluginDataPathText"
                                       Width="420"
                                       Opacity="0.82"
                                       TextWrapping="Wrap" />
                        </ui:SettingsExpanderItem.Footer>
                    </ui:SettingsExpanderItem>
                </StackPanel>
                <ui:SettingsExpander.Footer>
                    <Button x:Name="ResetPluginDataBtn"
                            Click="OnResetPluginDataClick"
                            MinWidth="140"
                            Content="重置插件数据" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</ci:SettingsPageBase>
